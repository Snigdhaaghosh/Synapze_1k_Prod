{
  "title": "Synapze Enterprise",
  "uid": "synapze-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Request Rate (rpm)",
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 4},
      "targets": [{"expr": "rate(synapze_http_requests_total[1m]) * 60", "legendFormat": "RPM"}]
    },
    {
      "id": 2, "type": "stat", "title": "Error Rate",
      "gridPos": {"x": 4, "y": 0, "w": 4, "h": 4},
      "targets": [{"expr": "rate(synapze_http_requests_total{status=~'5..'}[5m]) / rate(synapze_http_requests_total[5m])", "legendFormat": "Error %"}]
    },
    {
      "id": 3, "type": "stat", "title": "Active Streams",
      "gridPos": {"x": 8, "y": 0, "w": 4, "h": 4},
      "targets": [{"expr": "synapze_active_streams", "legendFormat": "Active"}]
    },
    {
      "id": 4, "type": "stat", "title": "Tokens / hour",
      "gridPos": {"x": 12, "y": 0, "w": 4, "h": 4},
      "targets": [{"expr": "rate(synapze_tokens_total[1h]) * 3600", "legendFormat": "Tokens"}]
    },
    {
      "id": 5, "type": "timeseries", "title": "Request Latency (p50/p95/p99)",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(synapze_http_request_duration_ms_bucket[5m]))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, rate(synapze_http_request_duration_ms_bucket[5m]))", "legendFormat": "p95"},
        {"expr": "histogram_quantile(0.99, rate(synapze_http_request_duration_ms_bucket[5m]))", "legendFormat": "p99"}
      ]
    },
    {
      "id": 6, "type": "timeseries", "title": "Tool Call Success Rate",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "targets": [
        {"expr": "rate(synapze_tool_calls_total{status='ok'}[5m])", "legendFormat": "{{tool}} OK"},
        {"expr": "rate(synapze_tool_calls_total{status='error'}[5m])", "legendFormat": "{{tool}} ERR"}
      ]
    }
  ]
}
