# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  Synapze Enterprise — Production Environment (1,000 concurrent users)        ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ── Core ──────────────────────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO
LOG_FORMAT=json
DEBUG=false

# ── Security ──────────────────────────────────────────────────────────────────
# python3 -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=REPLACE_WITH_128_CHAR_HEX

# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY

JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=20
ALLOWED_ORIGINS=["https://your-domain.com"]

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=8192
AGENT_MAX_ITERATIONS=15
AGENT_TOOL_TIMEOUT_SECS=30
ANTHROPIC_MAX_CONCURRENT=50        # cap concurrent API calls per process
ANTHROPIC_API_TIMEOUT_SECS=90

# ── Database — point to PgBouncer ────────────────────────────────────────────
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
DATABASE_URL=postgresql://synapze:REPLACE_WITH_STRONG_PASSWORD@pgbouncer:5432/synapze
DB_POOL_MIN=5
DB_POOL_MAX=25
DB_STATEMENT_CACHE_SIZE=0          # MUST be 0 for PgBouncer transaction mode

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
REDIS_URL=redis://:REPLACE_WITH_STRONG_PASSWORD@redis:6379/0
REDIS_MAX_CONNECTIONS=200
REDIS_SOCKET_TIMEOUT=3
REDIS_HEALTH_CHECK_INTERVAL=30

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=REPLACE_ME
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=REPLACE_ME
TWILIO_WHATSAPP_NUMBER=+14155238886

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-REPLACE_ME
SLACK_SIGNING_SECRET=REPLACE_ME

# ── OpenAI (semantic memory) ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-REPLACE_ME

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=https://REPLACE_ME@sentry.io/PROJECT_ID
SENTRY_TRACES_SAMPLE_RATE=0.05
# python3 -c "import secrets; print(secrets.token_hex(32))"
PROMETHEUS_SECRET=REPLACE_WITH_RANDOM_32_CHAR_HEX
PROMETHEUS_ENABLED=true

# ── Server tuning (1k users) ─────────────────────────────────────────────────
UVICORN_WORKERS=4                  # per API replica (4 × 2 replicas = 8 processes)
UVICORN_BACKLOG=2048
UVICORN_TIMEOUT_KEEP_ALIVE=75
UVICORN_LIMIT_MAX_REQUESTS=10000   # recycle worker after 10k requests (prevent leaks)
MAX_CONCURRENT_STREAMS=200         # per-process SSE cap
ANTHROPIC_MAX_CONCURRENT=50        # per-process Anthropic semaphore

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_WORKER_CONCURRENCY=16       # per worker replica (16 × 2 = 32 total)
CELERY_MAX_TASKS_PER_CHILD=500
CELERY_TASK_SOFT_LIMIT=300
CELERY_TASK_HARD_LIMIT=360

# ── Flower ────────────────────────────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
GRAFANA_ROOT_URL=https://monitoring.your-domain.com

# ── Proactive monitors ────────────────────────────────────────────────────────
MONITOR_EMAIL_INTERVAL_MINS=5
MONITOR_CALENDAR_INTERVAL_MINS=30
YOUR_WHATSAPP_NUMBER=+91XXXXXXXXXX

# ── Feature flags ─────────────────────────────────────────────────────────────
FEATURE_SEMANTIC_MEMORY=true
FEATURE_WORLD_MODEL=true
FEATURE_BROWSER_AGENT=true
FEATURE_PROACTIVE_MONITORS=true

# ── Sandbox ───────────────────────────────────────────────────────────────────
SANDBOX_ENABLED=false
BROWSER_HEADLESS=true
SANDBOX_TIMEOUT_SECS=30
